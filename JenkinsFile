pipeline {
    agent any
    tools {
        nodejs "NodeJS 18.0.0"   // must match the name you gave in Global Tool Config
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Install') {
            steps {
                dir('backend') {
                    bat 'npm install'
                }
            }
        }
        stage('Run') {
            steps {
                dir('backend') {
                    bat 'node server.js'
                }
            }
        }
    }
}
