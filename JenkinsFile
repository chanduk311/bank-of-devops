pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Install') {
            steps {
                dir('backend') {
                    bat 'npm install'
                }
            }
        }
        stage('Run') {
            steps {
                dir('backend') {
                    bat 'node server.js'
                }
            }
        }
    }
}
